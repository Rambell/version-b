@import './_variables'

:root
    --color-primary #6b46ff
    --color-primary-dark #5a35ee
    --color-accent #2cb7ff
    --color-accent-dark #0096db
    --color-text #2d3748
    --color-text-light #5b6987
    --color-bg #ffffff
    --color-bg-soft #f8f7ff
    --color-border #e2e8f0
    --color-bg-hover #1fa0e6

.dark
    --color-primary #7c5cff
    --color-accent #2cb7ff
    --color-text #f1f5f9
    --color-text-light #94a3b8
    --color-bg #0f0f1a
    --color-bg-soft #1a1a2e
    --color-border #2d2d44

// ==================
// RESET
// ==================
*
    box-sizing border-box
    margin 0
    padding 0

body
    font-family 'Poppins', sans-serif
    color var(--color-text)
    background var(--color-bg)
    transition background-color 0.3s ease, color 0.3s ease

:focus-visible
    outline 2px solid var(--color-primary)
    outline-offset 2px
    border-radius 4px

// ==================
// IMPORTS
// ==================
@import './layout/_header'
@import './layout/_footer'
@import './components/_hero'
@import './components/_course-card'
@import './components/_sidebar'
@import './components/_contact-form'