.hero

    &__announcement
        background #dc2626
        color #fff
        font-size 13px
        padding 10px 0

    &__announcement-container
        max-width 1440px
        margin 0 auto
        padding 0 40px
        display flex
        align-items center
        justify-content center
        position relative

    &__announcement-close
        background none
        border none
        color #fff
        cursor pointer
        font-size 16px
        opacity 0.8
        transition opacity 0.2s
        position absolute
        right 40px

        &:hover
            opacity 1

    &__main
        background var(--color-primary)
        background linear-gradient(135deg, var(--color-primary) 0%, #7c3aed 100%)
        color #fff
        padding 80px 16px

        @media (max-width: 768px)
            padding 48px 16px

    &__content
        max-width 700px
        margin 0 auto
        text-align center
        display flex
        flex-direction column
        align-items center
        gap 24px

    &__title
        font-size 40px
        font-weight 700
        line-height 1.2

        @media (max-width: 768px)
            font-size 28px

        &--highlight
            color #fde047

    &__subtitle
        color rgba(255,255,255,0.85)
        font-size 16px
        max-width 500px

        @media (max-width: 768px)
            font-size 14px

    &__search
        width 100%
        max-width 520px
        display flex
        align-items center
        border-bottom 2px solid rgba(255,255,255,0.6)
        padding-bottom 4px
        gap 8px

        &:focus-within
            border-bottom-color #fff

    &__search-input
        flex 1
        background transparent
        border none
        outline none
        color #fff
        font-size 15px
        font-family 'Poppins', sans-serif

        &::placeholder
            color rgba(255,255,255,0.5)

    &__search-btn
        background none
        border none
        color rgba(255,255,255,0.8)
        cursor pointer
        display flex
        align-items center
        transition color 0.2s

        &:hover
            color #fff

    &__quick-searches
        display flex
        flex-wrap wrap
        align-items center
        justify-content center
        gap 8px

    &__quick-label
        color rgba(255,255,255,0.8)
        font-size 13px

    &__quick-btn
        background transparent
        border 1px solid rgba(255,255,255,0.5)
        color #fff
        padding 4px 14px
        border-radius 999px
        font-size 13px
        font-weight 600
        cursor pointer
        font-family 'Poppins', sans-serif
        transition background 0.2s

        &:hover
            background rgba(255,255,255,0.15)