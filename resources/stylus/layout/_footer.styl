.footer
    background #3a3f5a
    color #fff
    font-family 'Poppins', sans-serif

    &__main
        padding 64px 0

    &__container
        max-width 1440px
        margin 0 auto
        padding 0 40px
        display grid
        grid-template-columns 1fr 1fr 1fr 1fr 1fr
        gap 32px

        @media (max-width: 1024px)
            grid-template-columns repeat(3, 1fr)

        @media (max-width: 768px)
            grid-template-columns repeat(2, 1fr)

        @media (max-width: 480px)
            grid-template-columns 1fr

    &__logo
        width 160px
        filter brightness(0) invert(1)
        margin-bottom 24px

    &__countries-label
        font-size 11px
        font-weight 700
        text-transform uppercase
        letter-spacing 0.1em
        color #9ca3af
        display block
        margin-bottom 12px

    &__countries-list
        list-style none
        padding 0
        margin 0
        display flex
        flex-direction column
        gap 10px

    &__country
        display flex
        align-items center
        gap 10px
        font-size 13px
        font-weight 700
        cursor pointer
        transition color 0.2s

        &:hover
            color #93c5fd

    &__col--stacked
        display flex
        flex-direction column
        gap 32px

    &__group
        display flex
        flex-direction column
        gap 12px

    &__group-title
        font-size 13px
        font-weight 700
        text-transform uppercase
        letter-spacing 0.1em
        color #8494C9
        padding-bottom 8px
        border-bottom 1px solid rgba(255,255,255,0.1)

    &__links
        list-style none
        padding 0
        margin 0
        display flex
        flex-direction column
        gap 8px

    &__link
        font-size 12px
        font-weight 700
        color #d1d5db
        text-decoration none
        text-transform uppercase
        transition color 0.2s

        &:hover
            color #fff

    &__contact-list
        list-style none
        padding 0
        margin 0 0 20px 0
        display flex
        flex-direction column
        gap 12px

    &__contact-item
        display flex
        align-items center
        gap 10px
        font-size 13px
        color #d1d5db

        &--address
            align-items flex-start

    &__contact-links
        display flex
        flex-direction column
        gap 8px

    &__contact-link
        font-size 12px
        font-weight 700
        color #d1d5db
        text-decoration underline
        cursor pointer
        transition color 0.2s

        &:hover
            color #fff

        &--highlight
            color #fff
            font-style italic
            text-decoration none

    // Newsletter
    &__newsletter
        background rgba(255,255,255,0.05)
        border 1px solid rgba(255,255,255,0.1)
        border-radius 16px
        padding 20px
        min-height 350px
        display flex
        flex-direction column

    &__newsletter-form
        display flex
        flex-direction column
        gap 12px

    &__newsletter-title
        font-size 13px
        font-weight 700
        text-transform uppercase
        margin-bottom 4px

    &__newsletter-field
        display flex
        flex-direction column
        gap 4px

    &__newsletter-label
        font-size 10px
        font-weight 700
        text-transform uppercase
        color #9ca3af

        &--error
            color #f87171

    &__newsletter-input
        background #fff
        color #1a1a2e
        border none
        border-radius 6px
        padding 6px 12px
        font-size 13px
        font-family 'Poppins', sans-serif
        outline none

        &--error
            border 2px solid #f87171

    &__newsletter-error
        font-size 11px
        color #f87171
        min-height 14px

    &__newsletter-btn
        background #2cb7ff
        color #fff
        border none
        border-radius 6px
        padding 8px
        font-size 13px
        font-weight 700
        cursor pointer
        font-family 'Poppins', sans-serif
        transition background 0.2s
        margin-top 4px

        &:hover
            background darken(#2cb7ff, 10%)

        &:disabled
            opacity 0.5
            cursor not-allowed

    &__newsletter-success
        display flex
        flex-direction column
        align-items center
        justify-content center
        flex 1
        text-align center
        gap 12px

        h4
            font-size 14px
            font-weight 700
            text-transform uppercase

        p
            font-size 12px
            color #9ca3af

    &__newsletter-reset
        background none
        border none
        color #2cb7ff
        font-size 11px
        cursor pointer
        font-family 'Poppins', sans-serif

        &:hover
            text-decoration underline

    // Bottom bar
    &__bottom
        background #2a2e45
        padding 24px 0

    &__bottom-container
        max-width 1440px
        margin 0 auto
        padding 0 40px
        display flex
        align-items center
        justify-content space-between
        gap 16px

        @media (max-width: 768px)
            flex-direction column

    &__socials
        display flex
        align-items center
        gap 12px

    &__social-link
        width 36px
        height 36px
        border-radius 50%
        background #fff
        color #3a3f5a
        display flex
        align-items center
        justify-content center
        text-decoration none
        transition all 0.2s

        &:hover
            background #2cb7ff
            color #fff
            transform translateY(-2px)

    &__copyright
        font-size 13px
        color #9ca3af
        font-weight 500